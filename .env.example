# =============================================================================
# Servidor
# =============================================================================
PORT=8020

# Intervalo do cron job (formato cron padrão)
# Exemplos: "*/5 * * * *" = a cada 5 min | "*/15 * * * *" = a cada 15 min
CRON_INTERVAL="*/15 * * * *"

# =============================================================================
# Links WAN — IDs de servidores Ookla
# Encontre IDs válidos em: https://www.speedtest.net/speedtest-servers.php
# ou execute: speedtest --list | grep "nome-do-seu-isp"
# =============================================================================
WAN1_SERVER_ID=12345
WAN2_SERVER_ID=67890

# Nomes de exibição das interfaces (usados nos logs e alertas)
WAN1_NAME=WAN_1
WAN2_NAME=WAN_2

# =============================================================================
# Limites de alerta (em Mbps)
# Uma notificação push é disparada quando os valores ficam abaixo destes limites
# =============================================================================
WAN1_MIN_DOWNLOAD=300
WAN1_MIN_UPLOAD=100
WAN1_MAX_PING=80

WAN2_MIN_DOWNLOAD=300
WAN2_MIN_UPLOAD=100
WAN2_MAX_PING=80


# =============================================================================
# Banco de dados SQLite
# Caminho dentro do container (mapeado pelo volume ./data:/data)
# =============================================================================
DB_PATH=/data/speed_tests.db
